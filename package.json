{
 "name": "tidy-deps",
 "version": "2.0.1",
 "description": "Easily detect and remove unused dependencies",
 "main": "dist/index.js",
 "files": ["dist"],
 "scripts": {
  "build": "tsc",
  "postbuild": "node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'));\"",
  "start": "ts-node src/index.ts",
  "test": "vitest run",
  "prepublishOnly": "npm run build"
 },
 "bin": {
  "tidy-deps": "dist/index.js"
 },
 "engines": {
  "node": ">=16"
 },
 "keywords": [
  "dependencies",
  "clean dependencies",
  "remove unused dependencies",
  "unused dependencies",
  " clean",
  "npm",
  "yarn",
  "pnpm"
 ],
 "author": "Tariq Yunusa",
 "license": "MIT",
 "devDependencies": {
  "@types/node": "^24.5.1",
  "@types/yarnpkg__lockfile": "^1.1.9",
  "ts-node": "^10.9.2",
  "tsx": "^4.20.5",
  "typescript": "^5.9.2",
  "vitest": "^3.2.4"
 },
 "dependencies": {
  "@yarnpkg/lockfile": "^1.1.0",
  "chalk": "^5.0.0",
  "commander": "^12.1.0",
  "ora": "^8.0.0",
  "yaml": "^2.8.1"
 }
}
